# =============================================
# ClipGenius Environment Configuration
# =============================================
# Copy this file to .env and fill in your values
# .env is gitignored - NEVER commit real credentials

# --- Firebase Configuration ---
# Register & Get from: https://console.firebase.google.com/
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_APP_ID="1:123456789:web:abcdef"
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_FIRESTORE_DB="your-firestore-database-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789"

# --- Gemini API Key ---
# Default provider for all AI features. Get from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY="your-gemini-api-key"

# --- Per-Feature Provider & Model Overrides ---
# PROVIDER: which AI provider to use for this feature
#   "gemini"  — use Gemini (default, requires VITE_GEMINI_API_KEY)
#   "minimax" — use Minimax (requires VITE_MINIMAX_API_KEY)
# MODEL: leave empty to use the defaults listed below

# Clipboard Content Analysis — generates suggested name & summary
# Default provider: gemini | Default model: gemini-3-flash-preview
VITE_ANALYSIS_PROVIDER=""
VITE_ANALYSIS_MODEL=""

# Chat
# Default provider: gemini | Default model: gemini-3.1-pro-preview
VITE_CHAT_PROVIDER=""
VITE_CHAT_MODEL=""

# Live Voice
# Default provider: gemini | Default model: gemini-3.1-flash-live-preview
VITE_LIVE_PROVIDER=""
VITE_LIVE_MODEL=""

# Image Generation - Standard (Free)
# Default provider: gemini | Default model: gemini-2.5-flash-image
VITE_IMAGE_STANDARD_PROVIDER=""
VITE_IMAGE_STANDARD_MODEL=""

# Image Generation - PRO (Paid)
# Default provider: gemini | Default model: gemini-3-pro-image-preview
VITE_IMAGE_PRO_PROVIDER=""
VITE_IMAGE_PRO_MODEL=""

# --- Minimax API Configuration (used when provider is "minimax") ---
# See: https://platform.minimaxi.com/docs/api-reference/text-anthropic-api
# Get API Key from: https://platform.minimaxi.com/
VITE_MINIMAX_API_KEY=""
VITE_MINIMAX_BASE_URL="https://api.minimax.chat"

# --- App URL ---
VITE_APP_URL="http://localhost:3000"
